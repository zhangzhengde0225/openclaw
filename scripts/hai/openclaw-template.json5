{
  models: {
    mode: "merge",
    providers: {
      hepai: {
        baseUrl: "https://aiapi.ihep.ac.cn/apiv2",
        apiKey: "${HEPAI_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "aliyun/qwen3-max",
            name: "Qwen 3 Max (HepAI)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 8192,
          },
          {
            id: "openai/gpt-5",
            name: "GPT-5 (HepAI)",
            reasoning: false,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 16384,
          },
          {
            id: "deepseek-ai/deepseek-v3.2",
            name: "DeepSeek v3.2 (HepAI)",
            reasoning: false,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 16384,
          },
        ],
      },
    },
  },
  agents: {
    defaults: {
      model: { primary: "hepai/aliyun/qwen3-max" },
    },
  },
  gateway: {
    mode: "local",
  },
}
